NODE_ENV=development

# API
API_PORT=3333
API_BASE_URL=http://localhost:3333
CLIENTE_BASE_URL=http://localhost:5173
ADMIN_BASE_URL=http://localhost:5174
JWT_SECRET=change-me
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# MySQL (valores fictícios — copie para .env local e preencha)
DATABASE_URL=mysql://guia:guia@127.0.0.1:3306/guia_chapada

# WordPress atual, somente leitura para migracao
WP_DATABASE_URL=mysql://wp_user:wp_password@localhost:3306/wordpress_db
WP_SITE_URL=https://exemplo.com
# Opcional: base para npm run scrape:live-images (padrão www.guiachapadaveadeiros.com)
# LIVE_SITE_BASE=https://www.guiachapadaveadeiros.com
# SCRAPE_RESET_CADASTR=1 — use junto do scrape para limpar featured_image que era só selo Cadastur
# Pasta uploads local (migracao). Para copiar ao site: npm run sync:wp-media
# WP_UPLOADS_PATH=../guia chapada veadeiros/wp-content/uploads
# WP_UPLOADS_SOURCE=D:\caminho\para\uploads
WP_UPLOADS_PATH=../wp-content/uploads
WP_TABLE_PREFIX=wp_

# Cloudflare R2 (substitua pelos seus IDs/URLs)
R2_ACCOUNT_ID=
R2_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com/nome-do-bucket
R2_BUCKET=nome-do-bucket
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
# URL pública usada pela API ao montar links de mídia (sem barra final)
MEDIA_PUBLIC_URL=https://exemplo.com/imagens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Primeiro usuario admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
