generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AppLocale {
  pt
  en
  es
}

enum SeoEntityType {
  POST
  PAGE
  PRODUCT
  CATEGORY
  TAG
}

model User {
  id           Int      @id @default(autoincrement())
  name         String?
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(EDITOR)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  posts        Post[]

  @@map("users")
}

model Post {
  id             Int           @id @default(autoincrement())
  title          String
  slug           String        @unique
  excerpt        String?       @db.Text
  content        String        @db.LongText
  featuredImage  String?       @map("featured_image")
  featuredImageAlt String?     @db.Text @map("featured_image_alt")
  seoTitle       String?       @map("seo_title")
  seoDescription String?       @db.Text @map("seo_description")
  seoKeywords    String?       @db.Text @map("seo_keywords")
  seoFocusKeyword String?      @db.VarChar(255) @map("seo_focus_keyword")
  ogTitle        String?       @db.VarChar(512) @map("og_title")
  ogDescription  String?       @db.Text @map("og_description")
  seoRobots      String?       @db.VarChar(96) @map("seo_robots")
  status         PublishStatus @default(DRAFT)
  authorId       Int?          @map("author_id")
  publishedAt    DateTime?     @map("published_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  author         User?         @relation(fields: [authorId], references: [id])
  categories     Category[]    @relation("PostCategories")
  tags           Tag[]         @relation("PostTags")
  translations   PostTranslation[]

  @@index([slug])
  @@index([status, publishedAt])
  @@map("posts")
}

model PostTranslation {
  id                Int       @id @default(autoincrement())
  postId            Int       @map("post_id")
  locale            AppLocale
  title             String    @db.VarChar(512)
  slug              String    @db.VarChar(320)
  excerpt           String?   @db.Text
  content           String    @db.LongText
  seoTitle          String?   @map("seo_title") @db.VarChar(512)
  seoDescription    String?   @map("seo_description") @db.Text
  seoKeywords       String?   @map("seo_keywords") @db.Text
  seoFocusKeyword   String?   @map("seo_focus_keyword") @db.VarChar(255)
  ogTitle           String?   @map("og_title") @db.VarChar(512)
  ogDescription     String?   @map("og_description") @db.Text
  seoRobots         String?   @map("seo_robots") @db.VarChar(96)
  featuredImageAlt  String?   @map("featured_image_alt") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
  @@unique([locale, slug])
  @@index([postId])
  @@map("post_translations")
}

model Page {
  id             Int           @id @default(autoincrement())
  title          String
  slug           String        @unique
  excerpt        String?       @db.Text
  content        String        @db.LongText
  featuredImage  String?       @map("featured_image")
  seoTitle       String?       @map("seo_title")
  seoDescription String?       @db.Text @map("seo_description")
  status         PublishStatus @default(DRAFT)
  publishedAt    DateTime?     @map("published_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  translations   PageTranslation[]

  @@index([slug])
  @@map("pages")
}

model PageTranslation {
  id              Int       @id @default(autoincrement())
  pageId          Int       @map("page_id")
  locale          AppLocale
  title           String    @db.VarChar(512)
  slug            String    @db.VarChar(320)
  excerpt         String?   @db.Text
  content         String    @db.LongText
  seoTitle        String?   @map("seo_title") @db.VarChar(512)
  seoDescription  String?   @map("seo_description") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
  @@unique([locale, slug])
  @@index([pageId])
  @@map("page_translations")
}

model Product {
  id               Int           @id @default(autoincrement())
  title            String
  slug             String        @unique
  description      String        @db.LongText
  shortDescription String?       @db.Text @map("short_description")
  featuredImage    String?       @map("featured_image")
  price            Decimal?      @db.Decimal(10, 2)
  seoTitle         String?       @map("seo_title")
  seoDescription   String?       @db.Text @map("seo_description")
  status           PublishStatus @default(DRAFT)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  categories       Category[]    @relation("ProductCategories")
  tags             Tag[]         @relation("ProductTags")
  translations     ProductTranslation[]

  @@index([slug])
  @@map("products")
}

model ProductTranslation {
  id               Int       @id @default(autoincrement())
  productId        Int       @map("product_id")
  locale           AppLocale
  title            String    @db.VarChar(512)
  slug             String    @db.VarChar(320)
  description      String    @db.LongText
  shortDescription String?   @db.Text @map("short_description")
  seoTitle         String?   @map("seo_title") @db.VarChar(512)
  seoDescription   String?   @map("seo_description") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@unique([locale, slug])
  @@index([productId])
  @@map("product_translations")
}
model Category {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?   @db.Text
  parentId    Int?      @map("parent_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  posts       Post[]    @relation("PostCategories")
  products    Product[] @relation("ProductCategories")

  @@index([slug])
  @@map("categories")
}

model Tag {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  posts     Post[]    @relation("PostTags")
  products  Product[] @relation("ProductTags")

  @@index([slug])
  @@map("tags")
}

model Media {
  id        Int      @id @default(autoincrement())
  title     String?
  alt       String?
  url       String   @db.Text
  key       String   @unique
  width     Int?
  height    Int?
  mimeType  String   @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("media")
}

model SeoMetadata {
  id             Int           @id @default(autoincrement())
  entityType     SeoEntityType @map("entity_type")
  entityId       Int           @map("entity_id")
  seoTitle       String?       @map("seo_title")
  seoDescription String?       @db.Text @map("seo_description")
  canonicalUrl   String?       @db.Text @map("canonical_url")
  ogImage        String?       @db.Text @map("og_image")
  robots         String?

  @@unique([entityType, entityId])
  @@map("seo_metadata")
}

model Redirect {
  id         Int      @id @default(autoincrement())
  oldUrl     String   @unique @map("old_url")
  newUrl     String   @map("new_url")
  statusCode Int      @default(301) @map("status_code")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("redirects")
}

/** Lista de espera da plataforma de vendas (hero “Em breve”). Chave composta email+telefone (strings normalizadas). */
model WaitlistLead {
  email     String   @default("") @db.VarChar(255)
  phone     String   @default("") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([email, phone])
  @@map("waitlist_leads")
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.LongText
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
